# Copy to .env in this directory and fill in real values.
#   cp .env.example .env
# Never commit .env.

# -----------------------------------------------------------------------------
# proxy.ts — unified entry point (dual-mode)
# -----------------------------------------------------------------------------
# Mode 1 (CCR): When ccr-config.json exists and CCR_DISABLED is not set,
#   proxy.ts loads the embedded Claude Code Router for multi-provider routing,
#   tokenSaver, autoOrchestrate, etc. API keys/providers → ccr-config.json.
#
# Mode 2 (Legacy): When ccr-config.json is missing or CCR_DISABLED=1,
#   proxy.ts does simple Anthropic→OpenAI format conversion and forwards
#   to OPENAI_BASE_URL.

# ── Upstream (legacy mode only — CCR mode uses ccr-config.json providers) ──
# No trailing /v1 — proxy.ts appends /v1/chat/completions
OPENAI_BASE_URL=https://openrouter.ai/api
OPENAI_API_KEY=sk-or-v1-replace-me

# Local proxy port (proxy.ts listens here)
PROXY_PORT=18080

# Set to 1 to force legacy mode even when ccr-config.json exists
# CCR_DISABLED=0

# Set to 1 for verbose CCR debug logging
# CCR_LOG=0

# -----------------------------------------------------------------------------
# Claude Code CLI — talks to the local proxy
# -----------------------------------------------------------------------------
# start.sh sets ANTHROPIC_BASE_URL=http://127.0.0.1:$PROXY_PORT automatically.
ANTHROPIC_API_KEY=sk-or-v1-replace-me

# Model id: in CCR mode, routed by tokenSaver tiers; in legacy mode, mapped to
# an OpenRouter model name (e.g. claude-opus-4-6 → anthropic/claude-opus-4.6).
ANTHROPIC_MODEL=anthropic/claude-sonnet-4

DISABLE_TELEMETRY=1

# Strip Anthropic beta fields from tool schemas.
# Recommended when routing through CCR to non-Anthropic providers.
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=1

# -----------------------------------------------------------------------------
# CCR (Claude Code Router) — embedded in proxy.ts from src/router/
# -----------------------------------------------------------------------------
# All CCR routing config (providers, tokenSaver, autoOrchestrate) is in
# ccr-config.json, NOT here. See ccr-config.json for details.

# -----------------------------------------------------------------------------
# Messaging Gateway (gateway/) — connects chat platforms to the proxy
# -----------------------------------------------------------------------------
# Set to true/1 to start the gateway alongside the proxy
# GATEWAY_ENABLED=false

# Gateway home directory (holds config.yaml, sessions/, cron/output).
# Defaults to ~/.claude/gateway.
# GATEWAY_HOME=~/.claude/gateway

# ── Telegram ──
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_ALLOWED_USERS=user1,user2
# TELEGRAM_HOME_CHANNEL=-1001234567890

# ── Discord ──
# DISCORD_BOT_TOKEN=MTIz...
# DISCORD_ALLOWED_USERS=user1,user2
# DISCORD_HOME_CHANNEL=1234567890

# ── Slack ──
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ── 飞书 / Lark ──
# FEISHU_APP_ID=cli_...
# FEISHU_APP_SECRET=...
# FEISHU_CONNECTION_MODE=websocket
# FEISHU_PROJECT_CARD=true

# ── 企业微信 WeCom (AI Bot) ──
# WECOM_BOT_ID=...
# WECOM_BOT_SECRET=...

# ── 钉钉 DingTalk ──
# DINGTALK_CLIENT_ID=...
# DINGTALK_CLIENT_SECRET=...

# ── Matrix ──
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=syt_...
# MATRIX_USER_ID=@bot:matrix.org

# ── Signal ──
# SIGNAL_HTTP_URL=http://localhost:8080
# SIGNAL_ACCOUNT=+1234567890

# ── Mattermost ──
# MATTERMOST_URL=https://mattermost.example.com
# MATTERMOST_TOKEN=abc123

# ── Email ──
# EMAIL_ADDRESS=bot@example.com
# EMAIL_PASSWORD=...
# EMAIL_IMAP_HOST=imap.example.com
# EMAIL_SMTP_HOST=smtp.example.com

# ── SMS (Twilio) ──
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1234567890

# ── Home Assistant ──
# HASS_URL=http://homeassistant.local:8123
# HASS_TOKEN=eyJ...

# ── API Server (OpenAI-compatible endpoint) ──
# API_SERVER_ENABLED=true
# API_SERVER_PORT=8642
# API_SERVER_KEY=sk-...

# ── Webhook ──
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=8643
# WEBHOOK_SECRET=your-hmac-secret

# ── 微信 Weixin ──
# WEIXIN_TOKEN=...
# WEIXIN_ACCOUNT_ID=...

# ── 企业微信 WeCom Callback ──
# WECOM_CALLBACK_ENABLED=true
# WECOM_CALLBACK_CORP_ID=...
# WECOM_CALLBACK_TOKEN=...
# WECOM_CALLBACK_ENCODING_AES_KEY=...

# ── BlueBubbles (iMessage) ──
# BLUEBUBBLES_SERVER_URL=http://localhost:1234
# BLUEBUBBLES_PASSWORD=...

# ── WhatsApp ──
# WHATSAPP_ENABLED=true

# ── Global user access ──
# GATEWAY_ALLOW_ALL_USERS=true
# GATEWAY_ALLOWED_USERS=user1,user2
