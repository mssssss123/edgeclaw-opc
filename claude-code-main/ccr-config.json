    {
      "name": "judge",
      "api_base_url": "https://openrouter.ai/api/v1",
      "api_key": "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",
      "models": ["google/gemini-2.5-flash"]
    }
  ],
  "Router": {
    "default": "openrouter,google/gemini-2.5-flash",
    "tokenSaver": {
      "enabled": true,
      "judgeProvider": "judge",
      "judgeModel": "google/gemini-2.5-flash",
      "defaultTier": "MEDIUM",
      "tiers": {
        "SIMPLE": {
          "model": "openrouter,google/gemini-2.5-flash",
          "description": "Simple Q&A, file reads, greetings, small edits, quick lookups"
        },
        "MEDIUM": {
          "model": "openrouter,google/gemini-2.5-flash",
          "description": "Moderate coding tasks, single-file edits, explanations, code review"
        },
        "COMPLEX": {
          "model": "openrouter,anthropic/claude-sonnet-4",
          "description": "Multi-step coding, architecture design, large refactors, debugging across files"
        },
        "REASONING": {
          "model": "openrouter,anthropic/claude-sonnet-4",
          "description": "Deep reasoning, novel algorithm design, complex system architecture, security analysis"
        }
      },
      "subagentPolicy": "inherit",
      "rules": [
        "Short prompts (<20 words) with no technical depth → SIMPLE",
        "Single-file edits, straightforward code review, explanations → MEDIUM",
        "Multi-file coding tasks, refactoring, debugging → COMPLEX",
        "Novel architecture, deep analysis, security audit, algorithmic problems → REASONING",
        "When unsure between adjacent tiers, pick the LOWER one (save tokens)"
      ]
    },
    "autoOrchestrate": {
      "enabled": true,
      "triggerTiers": ["COMPLEX", "REASONING"],
      "mainAgentModel": "openrouter,anthropic/claude-sonnet-4",
      "skillPath": "/Users/a1/Desktop/claw/edgeclaw-opc/.claude/prompts/auto-orchestrate.md",
      "slimSystemPrompt": true
    }
  },
  "tokenStats": {
    "enabled": true
  }
