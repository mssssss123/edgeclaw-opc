# edgeclaw-opc unified configuration
#
# Copy this file to .env in the repository root:
#   cp .env.example .env
#
# This root .env is the only user-facing config entry for this repo.
# Do not create claudecodeui/.env or claude-code-main/.env.

# -----------------------------------------------------------------------------
# Required: upstream OpenAI-compatible API
# -----------------------------------------------------------------------------
# No trailing /v1 — claude-code-main/proxy.ts appends the correct endpoint.
EDGECLAW_API_BASE_URL=https://openrouter.ai/api
EDGECLAW_API_KEY=sk-or-v1-replace-me
EDGECLAW_MODEL=claude-opus-4-6

# -----------------------------------------------------------------------------
# Optional: local runtime settings
# -----------------------------------------------------------------------------
EDGECLAW_PROXY_PORT=18080
SERVER_PORT=3001
VITE_PORT=5173
HOST=0.0.0.0
CONTEXT_WINDOW=160000

# Memory is enabled by default. Set 0/false/no/off to disable it.
EDGECLAW_MEMORY_ENABLED=1

# -----------------------------------------------------------------------------
# Optional: memory model overrides
# -----------------------------------------------------------------------------
# Leave these empty to inherit the main EDGECLAW_API_* + EDGECLAW_MODEL config.
#
# Only set EDGECLAW_MEMORY_MODEL when you want a different memory model on the
# same gateway and API key.
#
# Set the full EDGECLAW_MEMORY_* group when memory should use a separate model
# provider / base URL / API key / API type.
# EDGECLAW_MEMORY_MODEL=
# EDGECLAW_MEMORY_BASE_URL=
# EDGECLAW_MEMORY_API_KEY=
# EDGECLAW_MEMORY_API_TYPE=openai-responses
# EDGECLAW_MEMORY_PROVIDER=edgeclaw_memory

# -----------------------------------------------------------------------------
# Optional: CloudCLI auth / path overrides
# -----------------------------------------------------------------------------
# CLOUDCLI_DISABLE_LOCAL_AUTH=0
# CLAUDE_CODE_MAIN_DIR=/absolute/path/to/claude-code-main

# -----------------------------------------------------------------------------
# Optional: messaging gateway (all configured in the same root .env)
# -----------------------------------------------------------------------------
# Set to 1/true to start the gateway alongside Claude Code CLI.
# Use `./claude-code-main/start.sh --gateway` to run gateway-only mode.
# GATEWAY_ENABLED=false
# GATEWAY_ALLOW_ALL_USERS=true
# GATEWAY_ALLOWED_USERS=user1,user2

# ── Telegram ──
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_ALLOWED_USERS=user1,user2
# TELEGRAM_HOME_CHANNEL=-1001234567890

# ── Discord ──
# DISCORD_BOT_TOKEN=MTIz...
# DISCORD_ALLOWED_USERS=user1,user2
# DISCORD_HOME_CHANNEL=1234567890

# ── Slack ──
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ── Feishu / Lark ──
# FEISHU_APP_ID=cli_...
# FEISHU_APP_SECRET=...
# FEISHU_CONNECTION_MODE=websocket
# FEISHU_PROJECT_CARD=true

# ── WeCom (AI Bot) ──
# WECOM_BOT_ID=...
# WECOM_BOT_SECRET=...

# ── DingTalk ──
# DINGTALK_CLIENT_ID=...
# DINGTALK_CLIENT_SECRET=...

# ── Matrix ──
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=syt_...
# MATRIX_USER_ID=@bot:matrix.org

# ── Signal ──
# SIGNAL_HTTP_URL=http://localhost:8080
# SIGNAL_ACCOUNT=+1234567890

# ── Mattermost ──
# MATTERMOST_URL=https://mattermost.example.com
# MATTERMOST_TOKEN=abc123

# ── Email ──
# EMAIL_ADDRESS=bot@example.com
# EMAIL_PASSWORD=...
# EMAIL_IMAP_HOST=imap.example.com
# EMAIL_SMTP_HOST=smtp.example.com

# ── SMS (Twilio) ──
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1234567890

# ── Home Assistant ──
# HASS_URL=http://homeassistant.local:8123
# HASS_TOKEN=eyJ...

# ── API Server (OpenAI-compatible endpoint) ──
# API_SERVER_ENABLED=true
# API_SERVER_PORT=8642
# API_SERVER_KEY=sk-...

# ── Webhook ──
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=8643
# WEBHOOK_SECRET=your-hmac-secret

# ── Weixin ──
# WEIXIN_TOKEN=...
# WEIXIN_ACCOUNT_ID=...

# ── WeCom Callback ──
# WECOM_CALLBACK_ENABLED=true
# WECOM_CALLBACK_CORP_ID=...
# WECOM_CALLBACK_TOKEN=...
# WECOM_CALLBACK_ENCODING_AES_KEY=...

# ── BlueBubbles (iMessage) ──
# BLUEBUBBLES_SERVER_URL=http://localhost:1234
# BLUEBUBBLES_PASSWORD=...

# ── WhatsApp ──
# WHATSAPP_ENABLED=true
